{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "backend.app"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Serve Frontend",
      "type": "shell",
      "command": "npm",
      "args": ["run", "start"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Start All (Backend + Frontend)",
      "type": "shell",
      "dependsOn": ["Run Backend", "Serve Frontend"],
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
